# FoKS Intelligence - Environment Variables
# Copy this file to .env and adjust values

# Application
FOKS_ENV=development  # development, staging, production
FOKS_LOG_FILE=/Users/dnigga/Documents/_PROJECTS_OFICIAL/FoKS_Intelligence/logs/app.log

# Database
FOKS_DATABASE_PATH=/Users/dnigga/Documents/_PROJECTS_OFICIAL/FoKS_Intelligence/backend/data/conversations.db

# LM Studio Configuration
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1/chat/completions
LMSTUDIO_MODEL=qwen2.5-14b
LMSTUDIO_VISION_MODEL=  # Optional: vision-capable model name
LMSTUDIO_API_KEY=  # Optional: API key if LM Studio requires authentication

# Performance (M3 Optimized)
MAX_REQUEST_SIZE_MB=10
REQUEST_TIMEOUT_SECONDS=120
ENABLE_NEURAL_ENGINE=true

# Security (Production)
# API_KEY=  # Optional: API key for authentication
# ALLOWED_ORIGINS=http://localhost,http://127.0.0.1  # Comma-separated
# RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Monitoring (Optional)
# SENTRY_DSN=  # Sentry error tracking
# PROMETHEUS_PORT=9090  # Prometheus metrics port

# PostgreSQL (Production)
# DATABASE_URL=postgresql://user:password@localhost:5432/foks_intelligence
