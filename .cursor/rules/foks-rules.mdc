- ✅ **Testable** (pytest fixtures, dependency injection)
- ✅ **Linted** (Ruff) and **typed** (mypy)

**Code Template Pattern:**
```python
from typing import Optional
from pydantic import BaseModel, Field
from app.services.some_service import SomeService
from app.utils.logging_utils import get_logger

logger = get_logger(__name__)

class RequestModel(BaseModel):
    """Request validation model."""
    field: str = Field(..., description="Field description")

async def endpoint_handler(
    request: RequestModel,
    service: SomeService = Depends(get_service)
) -> ResponseModel:
    """Endpoint handler with proper layering."""
    logger.info("Processing request", extra={"field": request.field})
    try:
        result = await service.process(request)
        return ResponseModel(result=result)
    except SpecificException as e:
        logger.error("Processing failed", exc_info=True)
        raise HTTPException(status_code=400, detail=str(e))
```

