<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Unique label for this launch agent (separate from FoKS) -->
    <key>Label</key>
    <string>com.fbp.bootstrap</string>

    <!-- Program and arguments (no daemonization; let launchd manage lifecycle) -->
    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>-lc</string>
      <string>/Users/dnigga/Documents/_PROJECTS_OFICIAL/FoKS_Intelligence/ops/scripts/fbp_boot.sh</string>
    </array>

    <!-- Working directory for the process -->
    <key>WorkingDirectory</key>
    <string>/Users/dnigga/Documents/FBP_Backend</string>

    <!-- Start at user login -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Keep alive: restart if it exits unexpectedly -->
    <key>KeepAlive</key>
    <dict>
      <!-- Don't restart if the process exited successfully -->
      <key>SuccessfulExit</key>
      <false/>
    </dict>

    <!-- Process management: give it 30s to shut down gracefully -->
    <key>ExitTimeOut</key>
    <integer>30</integer>

    <!-- Throttle interval: minimum 5s between restart attempts -->
    <key>ThrottleInterval</key>
    <integer>5</integer>

    <!-- Explicit logging paths (best practice for macOS 15+) -->
    <!-- These replace manual file handling in the script -->
    <key>StandardOutPath</key>
    <string>/Users/dnigga/Library/Logs/FoKS/com.fbp.bootstrap.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/dnigga/Library/Logs/FoKS/com.fbp.bootstrap.err.log</string>

    <!-- Optional: environment variables for M3 optimization -->
    <key>EnvironmentVariables</key>
    <dict>
      <key>PYTHONUNBUFFERED</key>
      <string>1</string>
      <key>PYTHONDONTWRITEBYTECODE</key>
      <string>1</string>
      <!-- FBP_ROOT can be overridden; default is ~/Documents/FBP_Backend -->
      <key>FBP_ROOT</key>
      <string>/Users/dnigga/Documents/FBP_Backend</string>
    </dict>

    <!-- Resource limits for Apple Silicon M3 (16 GB RAM, 8 cores: 4P+4E) -->
    <!-- Soft limits (can be exceeded temporarily) -->
    <key>SoftResourceLimits</key>
    <dict>
      <!-- Max CPU seconds: generous for background automation service -->
      <key>CPU</key>
      <integer>3600</integer>
      <!-- Max file size: 2 GB (for logs, browser automation cache) -->
      <key>FileSize</key>
      <integer>2147483648</integer>
      <!-- Max memory: ~2.5 GB (Playwright, browser contexts) -->
      <key>Memory</key>
      <integer>2684354560</integer>
      <!-- Max open files: 2048 (Playwright needs many FDs) -->
      <key>OpenFiles</key>
      <integer>2048</integer>
    </dict>

    <!-- Umask: restrictive file creation (user read/write only) -->
    <key>Umask</key>
    <integer>0077</integer>

  </dict>
</plist>
