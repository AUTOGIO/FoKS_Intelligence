{
  // ============================================================
  // Cursor Workspace Settings — M3 iMac Optimized
  // System: iMac (Mac15,5), Apple M3 (8-core: 4P+4E), 16 GB RAM
  // OS: macOS 26.3 Beta (25D5087f)
  // ============================================================

  // ============================================================
  // PERFORMANCE & MEMORY OPTIMIZATION (M3-Specific)
  // ============================================================

  // TypeScript/JavaScript Language Server
  "typescript.tsserver.maxTsServerMemory": 4096,
  "typescript.tsserver.watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority",
    "synchronousWatchDirectory": true,
    "excludeDirectories": ["**/node_modules", "**/.git", "**/dist", "**/build"]
  },
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.variableTypes.enabled": true,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.enumMemberValues.enabled": true,

  // JavaScript Language Server
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.suggest.autoImports": true,
  "javascript.preferences.importModuleSpecifier": "relative",
  "javascript.inlayHints.parameterNames.enabled": "all",
  "javascript.inlayHints.variableTypes.enabled": true,

  // Python Language Server (Pylance/Pyright)
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.indexing": true,
  "python.analysis.packageIndexDepths": [
    { "name": "", "depth": 2 },
    { "name": "app", "depth": 3 }
  ],
  "python.analysis.memory.keepLibraryAst": true,
  "python.analysis.stubPath": "./backend",
  "python.analysis.extraPaths": [
    "./backend",
    "./backend/app"
  ],

  // File Watcher (M3-optimized: use native FSEvents)
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.venv*/**": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/logs/**": true,
    "**/uv.lock": true,
    "**/package-lock.json": true,
    "**/yarn.lock": true
  },

  // Search Exclusions (reduce indexing overhead)
  "search.exclude": {
    "**/node_modules": true,
    "**/.venv*": true,
    "**/__pycache__": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/logs": true,
    "**/uv.lock": true,
    "**/.pytest_cache": true
  },

  // ============================================================
  // EDITOR SETTINGS (GPU-Aware Rendering)
  // ============================================================

  "editor.renderWhitespace": "boundary",
  "editor.renderControlCharacters": false,
  "editor.renderLineHighlight": "gutter",
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.minimap.enabled": true,
  "editor.minimap.maxColumn": 120,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.highlightActiveIndentation": true,
  "editor.inlineSuggest.enabled": true,
  "editor.suggestSelection": "first",
  "editor.wordBasedSuggestions": "matchingDocuments",
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.suggest.showKeywords": true,
  "editor.suggest.showSnippets": true,
  "editor.suggest.localityBonus": true,
  "editor.suggest.shareSuggestSelections": true,
  "editor.acceptSuggestionOnCommitCharacter": true,
  "editor.acceptSuggestionOnEnter": "smart",
  "editor.tabCompletion": "on",
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "on"
  },
  "editor.quickSuggestionsDelay": 100,
  "editor.suggestOnTriggerCharacters": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnType": false,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.removeUnusedImports": "explicit"
  },

  // ============================================================
  // TERMINAL INTEGRATION (iTerm2 Profile)
  // ============================================================

  "terminal.integrated.defaultProfile.osx": "FoKS Intelligence — M3 Optimized",
  "terminal.integrated.profiles.osx": {
    "FoKS Intelligence — M3 Optimized": {
      "path": "/bin/zsh",
      "args": [
        "-lc",
        "cd \"$HOME/Documents/_PROJECTS_OFICIAL/FoKS_Intelligence\" && if [ -d backend/.venv_foks ]; then source backend/.venv_foks/bin/activate; fi && export PYTHONPATH=\"$HOME/Documents/_PROJECTS_OFICIAL/FoKS_Intelligence/backend:${PYTHONPATH:-}\" && export FOKS_ROOT=\"$HOME/Documents/_PROJECTS_OFICIAL/FoKS_Intelligence\" && exec /bin/zsh"
      ],
      "icon": "terminal"
    },
    "zsh": {
      "path": "/bin/zsh",
      "args": []
    },
    "bash": {
      "path": "/bin/bash",
      "args": []
    }
  },
  "terminal.integrated.inheritEnv": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontFamily": "JetBrainsMonoNerdFontComplete-Regular, 'JetBrains Mono', 'Fira Code', Menlo, Monaco, 'Courier New', monospace",
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.scrollback": 50000,

  // ============================================================
  // LANGUAGE-SPECIFIC FORMATTING
  // ============================================================

  // TypeScript/JavaScript
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // Python
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    "editor.rulers": [100],
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },

  // Markdown
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },

  // YAML
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  // Shell
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  // ============================================================
  // PRETTIER CONFIGURATION
  // ============================================================

  "prettier.enable": true,
  "prettier.requireConfig": false,
  "prettier.useEditorConfig": true,
  "prettier.printWidth": 100,
  "prettier.tabWidth": 2,
  "prettier.useTabs": false,
  "prettier.semi": true,
  "prettier.singleQuote": true,
  "prettier.trailingComma": "es5",
  "prettier.arrowParens": "avoid",
  "prettier.endOfLine": "lf",

  // ============================================================
  // ESLINT CONFIGURATION
  // ============================================================

  "eslint.enable": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.run": "onType",
  "eslint.format.enable": true,
  "eslint.codeActionsOnSave.mode": "all",

  // ============================================================
  // PYTHON CONFIGURATION
  // ============================================================

  "python.defaultInterpreterPath": "${workspaceFolder}/backend/.venv_foks/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingImports": "warning",
    "reportMissingTypeStubs": "none",
    "reportUnusedImport": "warning",
    "reportUnusedClass": "warning",
    "reportUnusedFunction": "warning",
    "reportUnusedVariable": "warning"
  },
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": false,
  "python.linting.flake8Enabled": false,
  "python.linting.ruffEnabled": true,
  "python.linting.ruffPath": "${workspaceFolder}/backend/.venv_foks/bin/ruff",
  "python.formatting.provider": "black",
  "python.formatting.blackPath": "${workspaceFolder}/backend/.venv_foks/bin/black",
  "python.testing.pytestEnabled": true,
  "python.testing.pytestPath": "${workspaceFolder}/backend/.venv_foks/bin/pytest",
  "python.testing.unittestEnabled": false,
  "python.testing.autoTestDiscoverOnSaveEnabled": true,

  // ============================================================
  // GIT CONFIGURATION
  // ============================================================

  "git.enabled": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.suggestSmartCommit": true,
  "git.ignoreLimitWarning": true,
  "git.autoRepositoryDetection": true,

  // ============================================================
  // FILE ASSOCIATIONS
  // ============================================================

  "files.associations": {
    "*.env": "dotenv",
    "*.env.*": "dotenv",
    "*.pyi": "python",
    "pyproject.toml": "toml",
    "uv.lock": "toml",
    "Makefile": "makefile",
    "*.plist": "xml",
    "*.shortcut.json": "jsonc"
  },

  // ============================================================
  // WORKSPACE-SPECIFIC SETTINGS
  // ============================================================

  "files.exclude": {
    "**/.pytest_cache": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true
  },

  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,

  // ============================================================
  // CURSOR AI SPECIFIC SETTINGS
  // ============================================================

  "cursor.ai.enableCodeActions": true,
  "cursor.ai.enableInlineCompletion": true,
  "cursor.ai.enableChat": true,

  // ============================================================
  // ADVANCED: M3 NEURAL ENGINE HINTS (if supported)
  // ============================================================

  // Note: These are experimental and may not be available in all Cursor versions
  // They hint at potential Metal/ANE acceleration for syntax highlighting
  "editor.semanticHighlighting.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",

  // ============================================================
  // MEMORY MANAGEMENT (16 GB RAM Optimization)
  // ============================================================

  // Limit extension host memory
  "extensions.autoCheckUpdates": true,
  "extensions.autoUpdate": false,

  // Reduce background indexing
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.venv*/**": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/logs/**": true
  }
}
